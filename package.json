{
  "name": "buku-lagu-katolik",
  "main": "buku_pozoo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "expo start --clear -c",
    "build:web": "EXPO_NO_TELEMETRY=1 expo export --platform web",
    "lint": "expo lint",
    "optimize:images": "powershell -Command \"Get-ChildItem './assets/images/' -Recurse -Include *.png | ForEach-Object { npx sharp-cli -i $_.FullName -o './assets/images-opt/'$($_.Name -replace '.png','.webp') -f webp -q 80 }\""
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/noto-serif": "^0.2.3",
    "@expo/vector-icons": "^14.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/slider": "^4.5.6",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "~52.0.38",
    "expo-blur": "^14.0.3",
    "expo-constants": "^17.0.5",
    "expo-font": "^13.0.3",
    "expo-haptics": "^14.0.1",
    "expo-image": "~2.0.6",
    "expo-linear-gradient": "^14.0.2",
    "expo-linking": "^7.0.5",
    "expo-optimize": "^0.2.20",
    "expo-router": "~4.0.19",
    "expo-splash-screen": "~0.29.22",
    "expo-status-bar": "^2.0.1",
    "expo-symbols": "^0.2.2",
    "expo-system-ui": "^4.0.7",
    "expo-web-browser": "^14.0.2",
    "lucide-react-native": "^0.475.0",
    "next": "^15.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "^3.16.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.19.13",
    "react-native-webview": "13.12.5",
    "remark-gfm": "^4.0.1",
    "sharp-cli": "^5.1.0",
    "webidl-conversions": "^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "@types/react-native": "^0.72.8",
    "typescript": "^5.3.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "lucide-react-native"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
